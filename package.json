{
  "name": "lspforge",
  "version": "0.5.0",
  "description": "LSP server manager for AI coding tools",
  "type": "module",
  "bin": {
    "lspforge": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "registry"
  ],
  "keywords": [
    "lsp",
    "mcp",
    "language-server",
    "claude-code",
    "copilot",
    "codex",
    "ai-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "js-yaml": "^4.1.1",
    "ofetch": "^1.5.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
